{
    "name": "pushberryfinn/laravel-domains",
    "description": "A Laravel package to manage and create modular domains inside your app",
    "keywords": [
        "laravel",
        "domains",
        "modules",
        "ddd",
        "pushberryfinn"
    ],
    "homepage": "https://github.com/pushberryfinn/laravel-domains",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Atdhe Krasniqi",
            "email": "atniqii@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Pushberryfinn\\LaravelDomains\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pushberryfinn\\LaravelDomains\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pushberryfinn\\LaravelDomains\\LaravelDomainsServiceProvider"
            ],
            "aliases": {
                "LaravelDomains": "Pushberryfinn\\LaravelDomains\\LaravelDomainsFacade"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
